# ============================================
# SmartAlbum Git Ignore File
# ============================================

# === Python ===
# 虚拟环境
venv/
env/
ENV/
.venv/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# === Node.js ===
# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# === IDE ===
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# === 操作系统 ===
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# === 应用数据 ===
# 数据库
data/*.db
data/*.db-journal
data/chroma/
data/vectors.json
*.sqlite
*.sqlite3

# 存储文件
storage/originals/*
storage/thumbnails/*
storage/ai_generated/*
!storage/originals/.gitkeep
!storage/thumbnails/.gitkeep
!storage/ai_generated/.gitkeep

# 日志文件
logs/
*.log
backend.log
frontend.log
celery.log

# 备份文件
backup/
*.backup
*.bak
*.swp
*.swo
*~

# 临时文件
tmp/
temp/
.tmp/
*.tmp

# === 敏感信息 ===
# 环境变量文件（保留示例文件）
.env
.env.local
.env.*.local
!.env.example

# 密钥和证书
*.pem
*.key
*.crt
*.p12
*.pfx

# === 构建产物 ===
# 前端构建
frontend/dist/
frontend/dist-ssr/
*.local

# 后端构建
backend/dist/
build/

# === Docker ===
.dockerignore
Dockerfile.local
docker-compose.override.yml

# === 测试 ===
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# === 其他 ===
# 压缩包
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# 下载的模型文件
*.pkl
*.h5
*.onnx
*.pb

# 大文件
*.psd
*.ai
*.sketch
