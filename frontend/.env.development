# ==========================================
# SmartAlbum 前端开发环境配置
# ==========================================

# API 基础地址（开发环境使用本地后端）
VITE_API_BASE_URL=http://localhost:9999

# 应用标题
VITE_APP_TITLE=SmartAlbum Dev

# 应用版本号
VITE_APP_VERSION=1.0.0

# 应用环境标识
VITE_APP_ENV=development

# ------------------------------------------
# 功能开关（开发环境全部开启）
# ------------------------------------------
VITE_ENABLE_AI=true
VITE_ENABLE_FACE_RECOGNITION=true
VITE_ENABLE_SEMANTIC_SEARCH=true
VITE_ENABLE_IMAGE_GENERATION=true
VITE_ENABLE_DEBUG=true

# ------------------------------------------
# 性能配置
# ------------------------------------------
VITE_LAZY_LOAD_THRESHOLD=300
VITE_THUMBNAIL_QUALITY=85
VITE_PAGE_SIZE=20
VITE_UPLOAD_CONCURRENCY=3

# ------------------------------------------
# 用户体验
# ------------------------------------------
VITE_PREVIEW_MAX_WIDTH=1920
VITE_AUTO_SAVE_INTERVAL=30000
VITE_MESSAGE_DURATION=3000

# ------------------------------------------
# 安全配置
# ------------------------------------------
VITE_REQUEST_TIMEOUT=30000
VITE_MAX_UPLOAD_SIZE=50
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,heic,heif
