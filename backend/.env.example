# ==========================================
# SmartAlbum 后端环境配置示例
# 复制此文件为 .env 并根据实际情况修改
# ==========================================

# ==========================================
# 基础配置（必填）
# ==========================================

# 运行环境: development | staging | production
ENVIRONMENT=development

# 应用调试模式: true | false
# 生产环境必须设置为 false
DEBUG=false

# JWT密钥（生产环境必须设置，至少32位随机字符串）
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# ==========================================
# 管理员账户配置
# ==========================================

# 默认管理员用户名
DEFAULT_USERNAME=admin

# 默认管理员密码（生产环境必须设置强密码）
DEFAULT_PASSWORD=your-secure-password

# ==========================================
# 数据库配置
# ==========================================

# 数据库连接URL（支持SQLite和PostgreSQL）
# SQLite: sqlite+aiosqlite:///./data/smartalbum.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/smartalbum
DATABASE_URL=sqlite+aiosqlite:///./data/smartalbum.db

# 数据库连接池大小
DATABASE_POOL_SIZE=5

# 数据库连接池溢出限制
DATABASE_MAX_OVERFLOW=10

# ==========================================
# Redis配置
# ==========================================

# Redis主机地址
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis数据库编号（0-15）
# 开发环境建议使用 11，生产环境使用 1
REDIS_DB=11

# Redis密码（如果没有密码留空）
REDIS_PASSWORD=

# ==========================================
# 存储配置
# ==========================================

# 存储根目录
STORAGE_PATH=./storage

# 原始图片存储路径
ORIGINALS_PATH=./storage/originals

# 缩略图存储路径
THUMBNAILS_PATH=./storage/thumbnails

# AI生成图片存储路径
AI_GENERATED_PATH=./storage/ai_generated

# ==========================================
# AI模型配置（推荐统一使用以下配置）
# ==========================================

# AI模型名称（显示用）
AI_MODEL_NAME=GPT-4o

# AI模型ID（API调用使用）
AI_MODEL_ID=gpt-4o

# AI API密钥（支持OpenAI/豆包等兼容OpenAI API格式的服务）
AI_API_KEY=your-ai-api-key

# AI API基础URL
# OpenAI: https://api.openai.com/v1
# 豆包: https://ark.cn-beijing.volces.com/api/v3
AI_API_BASE=https://api.openai.com/v1

# AI API路径
AI_API_PATH=/chat/completions

# AI请求超时时间（秒）
AI_TIMEOUT=120

# AI请求最大重试次数
AI_MAX_RETRIES=3

# ==========================================
# Embedding模型配置
# ==========================================

# Embedding模型名称
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Embedding模型ID
EMBEDDING_MODEL_ID=text-embedding-3-small

# Embedding API密钥（为空则使用AI_API_KEY）
EMBEDDING_API_KEY=

# Embedding API基础URL
EMBEDDING_API_BASE=https://api.openai.com/v1

# Embedding API路径
EMBEDDING_API_PATH=/embeddings

# 向量维度
EMBEDDING_DIMENSIONS=1536

# ==========================================
# 兼容旧配置（如已配置AI_API_KEY可忽略）
# ==========================================

# [兼容] OpenAI API密钥
OPENAI_API_KEY=

# [兼容] 豆包API密钥
DOUBAO_API_KEY=

# ==========================================
# 文件上传配置
# ==========================================

# 最大上传文件大小（字节）默认50MB
MAX_UPLOAD_SIZE=52428800

# 允许的文件扩展名（逗号分隔）
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.heic,.heif,.gif

# 上传分块大小（字节）默认1MB
UPLOAD_CHUNK_SIZE=1048576

# 最大并发上传数
MAX_CONCURRENT_UPLOADS=5

# ==========================================
# 缩略图配置
# ==========================================

# 缩略图质量（1-100）
THUMBNAIL_QUALITY=85

# 缩略图格式（JPEG|PNG|WEBP）
THUMBNAIL_FORMAT=JPEG

# 小缩略图尺寸
THUMBNAIL_SMALL_SIZE=(150, 150)

# 中缩略图尺寸
THUMBNAIL_MEDIUM_SIZE=(400, 400)

# 大缩略图尺寸
THUMBNAIL_LARGE_SIZE=(1920, 1080)

# ==========================================
# 腾讯云COS配置（可选）
# ==========================================

# 是否启用COS存储: true | false
COS_ENABLED=false

# COS SecretId
COS_SECRET_ID=

# COS SecretKey
COS_SECRET_KEY=

# COS存储桶名称
COS_BUCKET=

# COS区域
COS_REGION=ap-beijing

# COS CDN加速域名（可选）
COS_CDN_DOMAIN=

# COS对象键前缀
COS_PREFIX=development/

# COS签名URL过期时间（秒）
COS_EXPIRE_SECONDS=3600

# ==========================================
# 人脸识别配置
# ==========================================

# 是否启用人脸识别: true | false
FACE_ENABLED=true

# 人脸匹配阈值（0.1-1.0，越小越严格）
FACE_MATCH_THRESHOLD=0.6

# 最小人脸检测尺寸（像素）
FACE_MIN_SIZE=50

# 人脸检测模型（hog|cnn）
FACE_DETECTION_MODEL=hog

# 人脸编码模型（small|large）
FACE_ENCODING_MODEL=small

# ==========================================
# 文生图配置（火山引擎豆包）
# ==========================================

# 是否启用文生图: true | false
IMAGE_GEN_ENABLED=true

# 火山引擎AccessKey
VOLCENGINE_ACCESS_KEY=

# 火山引擎SecretKey
VOLCENGINE_SECRET_KEY=

# 文生图模型名称（为空使用AI_MODEL_NAME）
IMAGE_GEN_MODEL_NAME=

# 文生图模型ID（为空使用AI_MODEL_ID）
IMAGE_GEN_MODEL_ID=

# 文生图API密钥（为空使用AI_API_KEY）
IMAGE_GEN_API_KEY=

# 文生图API基础URL（为空使用AI_API_BASE）
IMAGE_GEN_API_BASE=

# 文生图API路径
IMAGE_GEN_API_PATH=/contents/generations/tasks

# 默认输出格式（png|jpeg|jpg|webp）
IMAGE_GEN_DEFAULT_FORMAT=png

# 是否添加水印: true | false
IMAGE_GEN_WATERMARK=false

# 文生图超时时间（秒）
IMAGE_GEN_TIMEOUT=300

# ==========================================
# CORS配置
# ==========================================

# 允许的CORS来源（逗号分隔，生产环境不要设置为*）
CORS_ORIGINS=http://localhost:8888,http://localhost:3000

# ==========================================
# 限流配置
# ==========================================

# 是否启用限流: true | false
RATE_LIMIT_ENABLED=true

# 默认限流规则
RATE_LIMIT_DEFAULT=100/minute

# 上传接口限流
RATE_LIMIT_UPLOAD=10/minute

# AI接口限流
RATE_LIMIT_AI=30/minute

# ==========================================
# 日志配置
# ==========================================

# 日志级别（DEBUG|INFO|WARNING|ERROR|CRITICAL）
LOG_LEVEL=INFO

# 日志格式（json|text）
LOG_FORMAT=text

# 是否启用文件日志: true | false
LOG_FILE_ENABLED=false

# 日志文件路径
LOG_FILE_PATH=./logs/smartalbum.log

# 日志文件最大大小（字节）
LOG_FILE_MAX_BYTES=10485760

# 日志文件备份数量
LOG_FILE_BACKUP_COUNT=5
