# ============================================
# SmartAlbum 生产环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# 应用配置
APP_NAME=SmartAlbum
DEBUG=False

# 数据库配置（Docker 环境使用相对路径）
DATABASE_URL=sqlite+aiosqlite:///./data/smartalbum.db

# Redis 配置（可选，不使用则留空）
# REDIS_URL=redis://localhost:6379/0

# ============================================
# AI 模型配置（豆包/火山引擎）
# ============================================

# 对话模型配置
AI_MODEL_NAME=doubao-seed-2-0-mini
AI_MODEL_ID=doubao-seed-2-0-mini-260215
AI_API_KEY=你的豆包API密钥
AI_API_BASE=https://ark.cn-beijing.volces.com/api/v3
AI_API_PATH=/responses

# 图片生成模型配置
IMAGE_GEN_MODEL_NAME=doubao-seedream-5-0
IMAGE_GEN_MODEL_ID=doubao-seedream-5-0-260128
IMAGE_GEN_API_KEY=你的豆包API密钥
IMAGE_GEN_API_BASE=https://ark.cn-beijing.volces.com/api/v3
IMAGE_GEN_API_PATH=/images/generations

# ============================================
# Embedding 模型配置（可选）
# ============================================

# EMBEDDING_MODEL_NAME=bce-embedding
# EMBEDDING_MODEL_ID=bce-embedding
# EMBEDDING_API_KEY=你的Embedding API密钥
# EMBEDDING_API_BASE=http://your-embedding-server:port
# EMBEDDING_API_PATH=/v1/embeddings

# ============================================
# 腾讯云COS存储配置（可选）
# ============================================

# 启用 COS 存储（true/false）
COS_ENABLED=false

# COS 配置（启用时需要填写）
# COS_SECRET_ID=你的SecretId
# COS_SECRET_KEY=你的SecretKey
# COS_BUCKET=your-bucket-name
# COS_REGION=ap-guangzhou
# COS_CDN_DOMAIN=可选的CDN域名

# ============================================
# 火山引擎 AK/SK（用于文生图API认证，可选）
# ============================================

# VOLCENGINE_ACCESS_KEY=你的AccessKey
# VOLCENGINE_SECRET_KEY=你的SecretKey

# ============================================
# CORS 配置
# ============================================

# 允许的源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173

# ============================================
# 人脸识别配置（可选）
# ============================================

# FACE_MATCH_THRESHOLD=0.6
# FACE_MIN_SIZE=50
# FACE_DETECTION_MODEL=hog
