# SmartAlbum 生产环境配置模板
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# AI API 配置（必填）
# ============================================

# OpenAI 兼容的 API 配置
AI_API_KEY=your_api_key_here
AI_MODEL_NAME=GPT-4o
AI_MODEL_ID=gpt-4o
AI_API_BASE=https://api.openai.com/v1

# 备用：豆包/火山引擎配置
# DOUBAO_API_KEY=your_doubao_key
# DOUBAO_MODEL=doubao-seed-2-0-mini-260215
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# ============================================
# Embedding 配置（可选，用于相似图片搜索）
# ============================================

# EMBEDDING_API_KEY=your_embedding_key
# EMBEDDING_MODEL_ID=text-embedding-3-small
# EMBEDDING_API_BASE=https://api.openai.com/v1

# ============================================
# 腾讯云 COS 配置（可选，推荐用于生产环境）
# ============================================

# 是否启用 COS 存储
COS_ENABLED=false

# COS 密钥（在腾讯云控制台获取）
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-name
COS_REGION=ap-beijing

# CDN 加速域名（可选）
# COS_CDN_DOMAIN=https://your-cdn-domain.com

# ============================================
# 火山引擎文生图配置（可选）
# ============================================

# VOLCENGINE_ACCESS_KEY=your_access_key
# VOLCENGINE_SECRET_KEY=your_secret_key

# ============================================
# 人脸识别配置（可选）
# ============================================

# 人脸匹配阈值（越小越严格，范围0-1）
# FACE_MATCH_THRESHOLD=0.6
# 最小人脸检测尺寸（像素）
# FACE_MIN_SIZE=50

# ============================================
# 应用配置（通常不需要修改）
# ============================================

# 调试模式（生产环境设置为 false）
DEBUG=false

# CORS 允许的来源（开发环境使用，生产环境自动允许所有）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库 URL（Docker 环境自动设置）
# DATABASE_URL=sqlite+aiosqlite:///./data/smartalbum.db

# Redis URL（Docker 环境自动设置）
# REDIS_URL=redis://redis:6379/0
